{
  "name": "llm-cost-estimator",
  "version": "0.1.0",
  "description": "Estimate token usage and cost across OpenAI, Anthropic, Gemini and more — as a library, CLI, and terminal dashboard.",
  "keywords": ["llm", "openai", "anthropic", "gemini", "tokens", "cost", "pricing", "ai", "cli"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "llm-cost": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pricing:verify": "node ./scripts/verify-pricing.mjs",
    "prepublishOnly": "npm run build && npm run test"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayank8025/llm-cost-estimator.git"
  },
  "bugs": {
    "url": "https://github.com/mayank8025/llm-cost-estimator/issues"
  },
  "homepage": "https://github.com/mayank8025/llm-cost-estimator#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ink": "^4.4.1",
    "js-tiktoken": "^1.0.12",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
